# MongoDB — docker compose up -d dan keyin (loyiha ildizi):
MONGODB_URI=mongodb://127.0.0.1:27017/soliqnazorat

# Demo parollar (npm run seed). Har biri alohida; bo‘sh qoldirilsa SEED_PASSWORD ishlatiladi.
SEED_PASSWORD_COMPANY=demo1234
SEED_PASSWORD_GASN=demo1234
SEED_PASSWORD_SOLIQ=demo1234
SEED_PASSWORD_MEHNAT=demo1234
# Barcha uchun umumiy zaxira (yuqorilardan biri bo‘lmasa shu ishlatiladi)
SEED_PASSWORD=demo1234

# JWT (productionda kuchli qiymat)
JWT_SECRET=your-secret-key

# Frontend manzili (Vite boshqa portda bo'lsa moslang, masalan http://localhost:5174)
CLIENT_ORIGIN=http://localhost:5173
